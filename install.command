#!/bin/bash
# Double-click this file on macOS to install. It opens Terminal and runs the
# installer for you. (First time: right-click the file and choose "Open".)
curl -fsSL https://raw.githubusercontent.com/AdirYad/claude-dev-setup/main/install.sh | bash
echo
read -n 1 -s -r -p "Press any key to close this window..."
echo
